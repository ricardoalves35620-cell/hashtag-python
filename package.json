{
  "name": "hashtag-python",
  "private": true,
  "version": "7.4.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build",
    "audit:install": "playwright install chromium",
    "audit:content": "tsx audit/content-audit.ts",
    "audit:visual": "playwright test",
    "audit": "npm run audit:content && npm run audit:visual",
    "audit:autopilot": "tsx audit/autopilot.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-python": "^6.1.3",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.26.0",
    "@supabase/supabase-js": "^2.43.0",
    "codemirror": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.23.0",
    "typescript": "^5.4.5",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.7"
  }
}
